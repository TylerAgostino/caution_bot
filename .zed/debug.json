// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "Debugpy",
    "label": "Flet",
    "request": "launch",
    "python": "$ZED_CUSTOM_PYTHON_ACTIVE_ZED_TOOLCHAIN",
    "cwd": "$ZED_WORKTREE_ROOT",
    "module": "BetterCautionBot",
  },
  {
    "adapter": "Debugpy",
    "label": "Test: Random Code 69",
    "request": "launch",
    "python": "$ZED_CUSTOM_PYTHON_ACTIVE_ZED_TOOLCHAIN",
    "cwd": "$ZED_WORKTREE_ROOT",
    "program": "${ZED_WORKTREE_ROOT}/tests/test_code69.py",
  },
  {
    "adapter": "Debugpy",
    "label": "Capture Telemetry",
    "request": "launch",
    "python": "$ZED_CUSTOM_PYTHON_ACTIVE_ZED_TOOLCHAIN",
    "cwd": "$ZED_WORKTREE_ROOT",
    "program": "${ZED_WORKTREE_ROOT}/tests/capture_telemetry.py",
    "args": [
      "--output",
      "tests/fixtures/capture.json",
      "--description",
      "my race",
      "--wave-arounds",
      "--auto-restart-get-ready-position",
      "0.85",
      "--auto-restart-form-lanes-position",
      "0.5",
      "--lane-names",
      "One,Two,Three",
    ],
  },
  {
    "adapter": "Debugpy",
    "label": "Test: Replay Fixtures",
    "request": "launch",
    "python": "$ZED_CUSTOM_PYTHON_ACTIVE_ZED_TOOLCHAIN",
    "cwd": "$ZED_WORKTREE_ROOT",
    "module": "pytest",
    "args": ["tests/test_fixtures.py", "-v"],
  },
]
